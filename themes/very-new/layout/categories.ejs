<div class="container">
    <div class="main-layout">
        <main>
            <div class="page-header">
                <h1 class="page-title">全部分类</h1>
            </div>
            <div class="category-list-page">
                <% site.categories.each(function(cat) { %>
                <a href="<%- url_for(cat.path) %>" class="category-row">
                    <span class="category-name"><%= cat.name %></span>
                    <span class="category-count"><%= cat.length %> 篇</span>
                </a>
                <% }) %>
            </div>
        </main>

        <aside class="sidebar">
            <div class="sidebar-section">
                <h3>关于我</h3>
                <p><%= theme.custom.author_bio %></p>
            </div>
        </aside>
    </div>
</div>
