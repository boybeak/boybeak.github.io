<div class="container">
    <div class="main-layout">
        <main>
            <div class="page-header">
                <h1 class="page-title">全部标签</h1>
            </div>
            <div class="tag-cloud-page">
                <% site.tags.each(function(tag) { %>
                <a href="<%- url_for(tag.path) %>" class="tag-cloud-item" style="font-size: <%= Math.max(0.85, Math.min(1.6, 0.85 + tag.length * 0.04)) %>rem;">
                    <%= tag.name %>
                    <span class="tag-cloud-count"><%= tag.length %></span>
                </a>
                <% }) %>
            </div>
        </main>

        <aside class="sidebar">
            <div class="sidebar-section">
                <h3>关于我</h3>
                <p><%= theme.custom.author_bio %></p>
            </div>
        </aside>
    </div>
</div>
