<div class="page-container">
  <h1 class="page-title">[ TAGS ]</h1>
  <div class="tag-cloud">
    <% site.tags.each(function(tag) { %>
    <a href="<%= config.root %><%= tag.path %>" class="tag-cloud-item" style="font-size: <%= Math.max(0.8, Math.min(1.8, 0.8 + tag.length * 0.05)) %>rem;">
      #<%= tag.name %> (<%= tag.length %>)
    </a>
    <% }) %>
  </div>
</div>
