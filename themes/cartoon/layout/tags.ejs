<div class="page-container">
  <h1 class="page-title">🏷️ 标签</h1>
  <div class="tag-cloud">
    <% site.tags.each(function(tag) { %>
    <a href="<%= config.root %><%= tag.path %>" class="tag-cloud-item" style="font-size: <%= Math.max(0.85, Math.min(2.0, 0.85 + tag.length * 0.05)) %>rem;">
      #<%= tag.name %>
      <span class="tag-cloud-count"><%= tag.length %></span>
    </a>
    <% }) %>
  </div>
</div>
