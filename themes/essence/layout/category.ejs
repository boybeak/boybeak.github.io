<% 
  function strip_html(str) {
    return str.replace(/<[^>]*>/g, '');
  }
  
  function truncate(str, length) {
    if (str.length <= length) return str;
    return str.substring(0, length) + '...';
  }
  
  function getAllImages(content) {
    if (!content) return [];
    const imgMatches = content.match(/<img[^>]+src="([^"]+)"/g);
    if (!imgMatches) return [];
    return imgMatches.map(match => {
      const srcMatch = match.match(/src="([^"]+)"/);
      return srcMatch ? srcMatch[1] : null;
    }).filter(Boolean);
  }
%>

<div class="article-container">
  <h1 class="page-title">分类：<%= page.category %></h1>
  <p class="category-description">包含 <%= page.posts.length %> 篇文章</p>
  
  <main class="article-list">
    <% page.posts.forEach(function(post) { %>
    <article class="article">
      <h2 class="article-title">
        <a href="<%- url_for(post.path) %>"><%= post.title %></a>
      </h2>
      <div class="article-meta">
        <time class="article-date" datetime="<%= date(post.date, 'YYYY-MM-DD') %>">
          <%= date(post.date, 'YYYY.MM.DD') %>
        </time>
        <% if (post.categories && post.categories.length > 0) { %>
          <% post.categories.forEach(function(category) { %>
            <a href="<%- url_for(category.path) %>" class="article-category"><%= category.name %></a>
          <% }); %>
        <% } %>
        <% if (post.tags && post.tags.length > 0) { %>
          <% post.tags.forEach(function(tag) { %>
            <a href="<%- url_for(tag.path) %>" class="article-tag"><%= tag.name %></a>
          <% }); %>
        <% } %>
      </div>
      <p class="article-summary">
        <%= post.excerpt ? truncate(strip_html(post.excerpt), 150) : truncate(strip_html(post.content), 150) %>
      </p>
      <% const images = getAllImages(post.excerpt || post.content); %>
      <% if (images.length > 0) { %>
        <% if (images.length === 1) { %>
          <div class="article-images single-image">
            <img src="<%= images[0] %>" alt="<%= post.title %>">
          </div>
        <% } else if (images.length <= 4) { %>
          <div class="article-images grid-4">
            <% images.forEach(function(img, index) { %>
              <div class="image-item">
                <img src="<%= img %>" alt="<%= post.title %> - 图片 <%= index + 1 %>">
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="article-images grid-9">
            <% images.slice(0, 9).forEach(function(img, index) { %>
              <div class="image-item">
                <img src="<%= img %>" alt="<%= post.title %> - 图片 <%= index + 1 %>">
                <% if (index === 8 && images.length > 9) { %>
                  <div class="image-overlay">
                    +<%= images.length - 9 %>
                  </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } %>
      <% } %>
    </article>
    <% }); %>
  </main>

  <% if (page.total > 1) { %>
  <nav class="pagination" aria-label="文章分页">
    <% if (page.prev) { %>
      <a href="<%- url_for(page.prev_link) %>" class="pagination-btn prev-btn">
        <span class="material-icons">chevron_left</span>
      </a>
    <% } else { %>
      <button class="pagination-btn prev-btn" disabled>
        <span class="material-icons">chevron_left</span>
      </button>
    <% } %>
    
    <div class="pagination-numbers">
      <% for (let i = 1; i <= page.total; i++) { %>
        <% if (i === page.current) { %>
          <span class="pagination-number active"><%= i %></span>
        <% } else { %>
          <a href="<%- url_for(i === 1 ? page.category : page.category + '/page/' + i + '/') %>" class="pagination-number"><%= i %></a>
        <% } %>
      <% } %>
    </div>
    
    <% if (page.next) { %>
      <a href="<%- url_for(page.next_link) %>" class="pagination-btn next-btn">
        <span class="material-icons">chevron_right</span>
      </a>
    <% } else { %>
      <button class="pagination-btn next-btn" disabled>
        <span class="material-icons">chevron_right</span>
      </button>
    <% } %>
  </nav>
  <% } %>
</div>

<style>
.page-title {
  margin-bottom: 0.5rem;
}

.category-description {
  color: var(--meta-color);
  margin-bottom: 2rem;
  font-size: 1rem;
}
</style>