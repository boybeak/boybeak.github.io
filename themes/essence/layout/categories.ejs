<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= page.title %> · <%= config.title %></title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <%- css('css/style.css') %>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <script>
      mermaid.initialize({ startOnLoad: true, theme: 'default' });
      // 处理Markdown代码块中的Mermaid语法
      document.addEventListener('DOMContentLoaded', function() {
        const codeBlocks = document.querySelectorAll('pre code[class*="mermaid"]');
        codeBlocks.forEach(function(block) {
          const mermaidDiv = document.createElement('div');
          mermaidDiv.className = 'mermaid';
          mermaidDiv.textContent = block.textContent;
          block.parentNode.replaceWith(mermaidDiv);
        });
      });
    </script>
    
    <% if (theme.seo.googleSiteVerification) { %>
    <meta name="google-site-verification" content="<%= theme.seo.googleSiteVerification %>" />
    <% } %>
    
    <% if (theme.seo.bingSiteVerification) { %>
    <meta name="msvalidate.01" content="<%= theme.seo.bingSiteVerification %>" />
    <% } %>
    
    <% if (theme.seo.googleAnalytics) { %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=<%= theme.seo.googleAnalytics %>"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '<%= theme.seo.googleAnalytics %>');
    </script>
    <% } %>
</head>
<body>
  <div class="container">
    <header class="site-header">
      <div class="header-row">
        <h1 class="site-title">
          <a href="<%= config.root %>">
            <% if (theme.custom.site_logo) { %>
            <img src="<%= theme.custom.site_logo %>" alt="<%= config.title %>" style="height: 32px; vertical-align: middle; margin-right: 10px;">
            <% } %>
            <%= config.title %>
          </a>
        </h1>
        <div class="nav-container">
          <nav class="main-nav">
            <ul class="nav-menu">
              <li class="nav-item">
                <a href="<%= config.root %>">首页</a>
              </li>
              <li class="nav-item dropdown">
                <a href="#" class="dropdown-toggle">分类</a>
                <ul class="dropdown-menu">
                  <li><a href="<%= config.root %>categories">全部分类</a></li>
                  <% site.categories.each(function(category) { %>
                  <li><a href="<%= config.root %><%= category.path %>"><%= category.name %></a></li>
                  <% }) %>
                </ul>
              </li>
              <li class="nav-item dropdown">
                <a href="#" class="dropdown-toggle">标签</a>
                <ul class="dropdown-menu">
                  <li><a href="<%= config.root %>tags">全部标签</a></li>
                  <% site.tags.each(function(tag) { %>
                  <li><a href="<%= config.root %><%= tag.path %>"><%= tag.name %></a></li>
                  <% }) %>
                </ul>
              </li>
              <li class="nav-item">
                <a href="<%= config.root %>about">关于</a>
              </li>
            </ul>
          </nav>
          <button class="theme-toggle" id="themeToggle" aria-label="切换夜间模式" title="切换夜间/日间模式">🌓</button>
        </div>
      </div>
      <div class="site-description">
        <%= config.subtitle %><br>
        <span style="font-size:0.9rem; border-left: none; padding-left:0; color: var(--footer-quote);">—— 内容为本，无关浮华</span>
      </div>
      
      <div class="author-info">
        <% if (theme.custom.author_avatar) { %>
        <div class="author-avatar">
          <img src="<%= theme.custom.author_avatar %>" alt="<%= theme.custom.author_name %>" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
        </div>
        <% } else { %>
        <div class="author-avatar">本</div>
        <% } %>
        <div class="author-details">
          <h3 class="author-name"><%= theme.custom.author_name %></h3>
          <p class="author-bio"><%= theme.custom.author_bio %></p>
          <div class="author-social">
            <% if (theme.custom.social_links && theme.custom.social_links.length > 0) { %>
            <% theme.custom.social_links.forEach(function(link) { %>
            <% if (link.url) { %>
            <a href="<%= link.url.indexOf('mailto:') === 0 ? link.url : link.url %>" class="social-link" title="<%= link.name.charAt(0).toUpperCase() + link.name.slice(1) %>" <%= link.url.indexOf('mailto:') === 0 ? '' : 'target="_blank"' %>>
              <% if (link.icon && (link.icon.indexOf('/') > -1 || link.icon.indexOf('.') > -1)) { %>
              <img src="<%= link.icon %>" alt="<%= link.name %>" style="width: 24px; height: 24px; object-fit: contain;">
              <% } else { %>
              <span class="material-icons"><%= link.icon %></span>
              <% } %>
            </a>
            <% } %>
            <% }); %>
            <% } %>
          </div>
        </div>
      </div>
    </header>

<div class="article-container">
  <h1 class="page-title">分类</h1>
  <div class="category-list">
    <% site.categories.each(function(category) { %>
    <div class="category-item">
      <h2 class="category-name">
        <a href="<%= config.root %><%= category.path %>"><%= category.name %></a>
      </h2>
      <p class="category-count"><%= category.length %> 篇文章</p>
    </div>
    <% }) %>
  </div>
</div>

<style>
.category-list {
  margin-top: 2rem;
}

.category-item {
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--border-light);
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 1.5rem;
  font-weight: 500;
  margin-bottom: 0.5rem;
}

.category-name a {
  color: var(--text-color);
  text-decoration: none;
  transition: color 0.15s ease;
}

.category-name a:hover {
  color: var(--link-hover);
  text-decoration: underline;
}

.category-count {
  color: var(--meta-color);
  font-size: 0.9rem;
  margin: 0;
}
</style>

    <footer class="site-footer">
      <span class="footer-copy">© <%= date(new Date(), 'YYYY') %> 本质</span>
      <span class="footer-quote">"少即是多"</span>
      <span class="footer-links">
        <a href="<%= config.root %>">首页</a>
        <a href="<%= config.root %>tags">标签</a>
        <a href="<%= config.root %>about">关于</a>
      </span>
    </footer>
  </div>

  <%- js('js/main.js') %>
</body>
</html>