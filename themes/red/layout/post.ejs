<main class="article-page">
  <a href="<%= config.root %>" class="back-link">◀ 返回首页</a>

  <article class="article-full">
    <header class="article-header">
      <div class="article-red-line"></div>
      <h1 class="article-title"><%= page.title %></h1>
      <div class="article-meta">
        <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>"><%= date(page.date, 'YYYY年MM月DD日') %></time>
        <% if (page.categories && page.categories.length > 0) { %><span class="article-meta-sep">|</span><% page.categories.forEach(function(cat){ %><a href="<%- url_for(cat.path) %>" class="article-cat"><%= cat.name %></a><% }); } %>
        <% if (page.tags && page.tags.length > 0) { %><span class="article-meta-sep">|</span><% page.tags.forEach(function(tag){ %><a href="<%- url_for(tag.path) %>" class="article-tag-link"><%= tag.name %></a><% }); } %>
      </div>
    </header>

    <div class="article-body">
      <%- page.content %>
    </div>
  </article>

  <div class="article-footer-nav">
    <a href="<%= config.root %>" class="back-to-list">◀ 返回首页</a>
  </div>
</main>
