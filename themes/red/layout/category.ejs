<% 
  function strip_html(str){ return str.replace(/<[^>]*>/g, ''); }
  function truncate(str, len){ if(str.length <= len) return str; return str.substring(0, len) + '...'; }
%>
<div class="page-container">
  <h1 class="page-title">分类：<%= page.category %></h1>
  <p class="page-desc">共 <%= page.posts.length %> 篇文章</p>
  <div class="post-list">
    <% page.posts.forEach(function(post) { %>
    <article class="post-item">
      <div class="post-head">
        <h2 class="post-title"><a href="<%- url_for(post.path) %>"><%= post.title %></a></h2>
        <div class="post-meta">
          <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'YYYY年MM月DD日') %></time>
          <% if (post.tags && post.tags.length) { %><span class="post-meta-sep">|</span><% post.tags.forEach(function(t){ %><a href="<%- url_for(t.path) %>"><%= t.name %></a><% }); } %>
        </div>
      </div>
      <p class="post-excerpt"><%= post.excerpt ? truncate(strip_html(post.excerpt), 200) : truncate(strip_html(post.content), 200) %></p>
    </article>
    <% }); %>
  </div>
  <% if (page.total > 1) { %>
  <nav class="pagination">
    <% if (page.prev) { %><a href="<%- url_for(page.prev_link) %>" class="page-arrow">◀ 上一页</a><% } else { %><span class="page-arrow disabled">◀ 上一页</span><% } %>
    <span class="page-info">第 <%= page.current %> 页 / 共 <%= page.total %> 页</span>
    <% if (page.next) { %><a href="<%- url_for(page.next_link) %>" class="page-arrow">下一页 ▶</a><% } else { %><span class="page-arrow disabled">下一页 ▶</span><% } %>
  </nav>
  <% } %>
</div>
