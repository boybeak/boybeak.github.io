<main class="article-single">
  <a href="<%= config.root %>" class="back-btn">
    <span class="material-icons-outlined">arrow_back</span>
    <span>返回</span>
  </a>

  <article class="card article-card">
    <header class="article-card-header">
      <h1 class="article-title"><%= page.title %></h1>
      <div class="article-meta-row">
        <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>">
          <span class="material-icons-outlined">calendar_today</span>
          <%= date(page.date, 'YYYY.MM.DD') %>
        </time>
        <% if (page.categories && page.categories.length > 0) { %>
          <% page.categories.forEach(function(cat) { %>
            <a href="<%- url_for(cat.path) %>" class="article-meta-cat"><%= cat.name %></a>
          <% }); %>
        <% } %>
      </div>
      <% if (page.tags && page.tags.length > 0) { %>
      <div class="article-tags-row">
        <% page.tags.forEach(function(tag) { %>
          <a href="<%- url_for(tag.path) %>" class="article-tag"><%= tag.name %></a>
        <% }); %>
      </div>
      <% } %>
    </header>

    <div class="article-body">
      <%- page.content %>
    </div>
  </article>
</main>
