<div class="page-container">
  <h1 class="page-title">标签</h1>
  <div class="tag-cloud">
    <% site.tags.each(function(tag) { %>
    <a href="<%= config.root %><%= tag.path %>" class="tag-cloud-item" style="font-size: <%= Math.max(0.8, Math.min(1.8, 0.8 + tag.length * 0.04)) %>rem;">
      <%= tag.name %>
      <span class="tag-cloud-count"><%= tag.length %></span>
    </a>
    <% }) %>
  </div>
</div>
