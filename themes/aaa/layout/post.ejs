<main class="article-page">
  <a href="<%= config.root %>" class="back-link">&larr; <span>返回文章列表</span></a>

  <article class="article-full">
    <header class="article-header">
      <h1 class="article-title"><%= page.title %></h1>
      <div class="article-meta">
        <time datetime="<%= date(page.date, 'YYYY-MM-DD') %>"><%= date(page.date, 'YYYY.MM.DD') %></time>
        <% if (page.categories && page.categories.length > 0) { %>
          <span class="article-meta-sep">/</span>
          <% page.categories.forEach(function(category) { %>
            <a href="<%- url_for(category.path) %>" class="article-cat"><%= category.name %></a>
          <% }); %>
        <% } %>
        <% if (page.tags && page.tags.length > 0) { %>
          <span class="article-meta-sep">/</span>
          <% page.tags.forEach(function(tag) { %>
            <a href="<%- url_for(tag.path) %>" class="article-tag-link"><%= tag.name %></a>
          <% }); %>
        <% } %>
      </div>
    </header>

    <div class="article-body">
      <%- page.content %>
    </div>
  </article>

  <div class="article-footer-nav">
    <a href="<%= config.root %>" class="back-to-list">&larr; 返回文章列表</a>
  </div>
</main>
